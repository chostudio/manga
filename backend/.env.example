# Copy to .env and fill in values: cp .env.example .env
# Never commit .env.

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
# Comma-separated hosts when DEBUG is false or for production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL (Supabase recommended; pgvector for vectors) ---
# For local dev without Postgres: leave DATABASE_URL unset and POSTGRES_DB empty (uses SQLite).
#
# Supabase: Dashboard → Project Settings → Database → Connection string → URI
#   Paste as DATABASE_URL (simplest), or set POSTGRES_* from the same screen instead.
#   Typical values: host db.<project-ref>.supabase.co, port 5432, database postgres, user postgres.
#   Use Session mode (port 5432) for Django; Transaction pooler (6543) is poor fit for the ORM.
# If DATABASE_URL is set, POSTGRES_* below are ignored.
DATABASE_URL=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
# Optional libpq sslmode (disable, allow, prefer, require, verify-ca, verify-full).
# If unset, hosts containing "supabase" default to "require".
# POSTGRES_SSLMODE=

# --- Amazon S3 (object storage for panel images) ---
# IAM user access keys: AWS Console → IAM → Users → Security credentials
# Or instance/task role in production (then leave access key vars empty).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_STORAGE_BUCKET_NAME=
# Optional: CloudFront or bucket website / custom hostname base for signed/public URLs returned to the frontend
AWS_S3_PUBLIC_BASE_URL=

# --- Image compression ---
# Optional Tinify (https://tinypng.com/developers) if you offload compression to their API
TINIFY_API_KEY=
# Local tuning (Pillow / encoder settings; no API key)
IMAGE_JPEG_QUALITY=85
IMAGE_AVIF_QUALITY=50
IMAGE_MAX_EDGE_PX=2048

# --- Web scraping (manga page ingestion) ---
# Use a real contact URL or project homepage in the user agent when scraping third-party sites.
SCRAPER_USER_AGENT=MangaIndexer/0.1 (+https://example.com/contact)
SCRAPER_REQUEST_TIMEOUT=30
# Optional HTTP(S) proxy for requests
SCRAPER_PROXY_URL=
# Optional third-party fetch/render APIs if you add them later
SCRAPER_ZENROWS_API_KEY=

# --- Embeddings (OpenCLIP / Hugging Face; add keys only if your pipeline needs them) ---
HUGGINGFACE_TOKEN=
# cpu | cuda — used when you wire local embedding inference
EMBEDDING_DEVICE=cpu
