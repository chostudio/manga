# Copy to .env and fill in values: cp .env.example .env
# Never commit .env.

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
# Comma-separated hosts when DEBUG is false or for production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL (vectors / app data via pgvector) ---
# Leave POSTGRES_DB empty or unset to use SQLite (backend/db.sqlite3) for local dev.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=manga
POSTGRES_USER=manga
POSTGRES_PASSWORD=

# --- Cloudflare R2 (S3-compatible object storage for panel images) ---
# API tokens: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional: custom domain or r2.dev public URL base for signed/public URLs returned to the frontend
R2_PUBLIC_BASE_URL=

# --- Image compression ---
# Optional Tinify (https://tinypng.com/developers) if you offload compression to their API
TINIFY_API_KEY=
# Local tuning (Pillow / encoder settings; no API key)
IMAGE_JPEG_QUALITY=85
IMAGE_AVIF_QUALITY=50
IMAGE_MAX_EDGE_PX=2048

# --- Web scraping (manga page ingestion) ---
# Use a real contact URL or project homepage in the user agent when scraping third-party sites.
SCRAPER_USER_AGENT=MangaIndexer/0.1 (+https://example.com/contact)
SCRAPER_REQUEST_TIMEOUT=30
# Optional HTTP(S) proxy for requests
SCRAPER_PROXY_URL=
# Optional third-party fetch/render APIs if you add them later
SCRAPER_ZENROWS_API_KEY=

# --- Embeddings (OpenCLIP / Hugging Face; add keys only if your pipeline needs them) ---
HUGGINGFACE_TOKEN=
# cpu | cuda — used when you wire local embedding inference
EMBEDDING_DEVICE=cpu
